<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>حالة</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
  <link rel="stylesheet" href="../styles.css">
  <link rel="icon" type="image/x-icon" href="icon.png">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@200;300;400;500;700;800;900&display=swap" rel="stylesheet">
</head>

<body>
  <div class="header">
    <div class="card">
      <div class="card-body" style="text-align: center;">
        <div class="contrainer">
          <% if (typeof err !== 'undefined' && err) { %>
          <div class="alert alert-danger" role="alert">
            <h2 class="tajawal-bold">صار خطأ</h2>
            <span class="tajawal-regular"><%= err.message %></span>
        </div>
            <% if (typeof err.ActaulMessage !== 'undefined' && err.ActaulMessage) { %>
           
            <br>
            <p class="tajawal-regular">:الرسالة اللي تحاول تحذفها</p>
            <span class="tajawal-light"><%= err.ActaulMessage %></span>
            <% } %>

          
          <% } %>

          <% if (typeof succ !== 'undefined' && succ) { %>
          <div class="alert alert-success" role="alert">
            <h2 class="tajawal-bold">!تـم</h2>
            <span class="tajawal-regular"><%= succ.message %></span>
          </div>
          <% if (typeof succ.ActaulMessage !== 'undefined' && succ.ActaulMessage) { %>
            <br>
            <p class="tajawal-regular">:الرسالة الي حذفتها</p>
            <span class="tajawal-light"><%= succ.ActaulMessage %></span>

            <% } %>
          <% if (typeof succ.transaction !== 'undefined' && succ.transaction) { %>
          <br>
          <h4 class="tajawal-bold">:معلومات الرسالة الي حطيتها</h4>

          <p class="tajawal-bold"><%= succ.transaction.Name %> :أسم المتجر</p>              
          <% if (succ.transaction.Amount > 0) { %>
          <p><span class="badge badge-success" style="font-size: medium;"><%= succ.transaction.Amount %> ﷼</span> :مبلغ</p>
          <% } else { %>
          <p><span class="badge badge-danger" style="font-size: medium;"><%= succ.transaction.Amount %> ﷼</span> :مبلغ</p>
          <% } %>
          <p class="tajawal-bold"><%= succ.transaction.Date %> :تاريخ</p>
          <p class="tajawal-bold">ملاحظات: <%= succ.transaction.Note %></p>
          <p class="tajawal-bold">:الرسالة المُدخلة</p>
          <p><%= succ.transaction.ActaulMessage %></p>
          <p class="tajawal-bold">:صورة الفاتورة</p>
          <img style="width: 250px;" src="<%= succ.transaction.ImagePath %>" alt="">
          <% } %>
          <% } %>
          <div class="form-group">
            <a href="/" class="tajawal-regular"><button class="btn btn-outline-secondary" style="width: 100%;">العودة</button></a>
          </div>

        </div>
      </div>

    </div>

    <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js" integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js" integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl" crossorigin="anonymous"></script>

</body>

</html>